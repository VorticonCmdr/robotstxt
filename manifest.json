{
  "manifest_version": 3,
  "name": "robots.txt emulator",
  "description": "blocks urls based on robots.txt",
  "version": "3.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    },
    "default_title": "robots.txt emulator",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "declarativeNetRequest",
    "webRequest",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
